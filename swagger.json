  "components": {
    "schemas": {
      "GenericObject": {
        "type": "object",
        "additionalProperties": true,
        "description": "Fallback schema used where source code has service-specific schema classes."
      }
    }
  },
  "x-amqp": {
    "description": "AMQP interfaces for AeroSell services (modeled as vendor extension in Swagger/OpenAPI).",
    "broker": {
      "protocol": "amqp",
      "urlEnv": "RABBITMQ_URL"
    },
    "exchanges": [
      {
        "name": "drone",
        "type": "direct",
        "usedBy": ["drone", "drone-simulator", "item-delivery"]
      },
      {
        "name": "drone_anomaly",
        "type": "topic",
        "usedBy": ["drone", "anomaly-manager"]
      },
      {
        "name": "drone_events",
        "type": "fanout",
        "usedBy": ["order", "item-delivery"]
      },
      {
        "name": "repair_exchange",
        "type": "direct",
        "usedBy": ["anomaly-manager"]
      },
      {
        "name": "repair_dlx",
        "type": "direct",
        "usedBy": ["anomaly-manager"]
      },
      {
        "name": "notification_exchange",
        "type": "topic",
        "usedBy": ["anomaly-manager"]
      }
    ],
    "queues": [
      {
        "name": "telemetry",
        "bindings": [{ "exchange": "drone", "routing_key": "telemetry" }],
        "consumers": ["drone"],
        "producers": ["drone-simulator"]
      },
      {
        "name": "flight_update",
        "bindings": [{ "exchange": "drone", "routing_key": "flight_update" }],
        "consumers": ["drone", "item-delivery"],
        "producers": ["drone-simulator"]
      },
      {
        "name": "notifications",
        "bindings": [{ "exchange": "", "routing_key": "notifications" }],
        "consumers": ["email-relay"],
        "producers": ["book-drone", "item-delivery", "anomaly-manager"]
      },
      {
        "name": "anomaly_recovery_queue",
        "bindings": [{ "exchange": "drone_anomaly", "routing_key": "drone.anomaly" }],
        "consumers": ["anomaly-manager"],
        "producers": ["drone"]
      },
      {
        "name": "repair_queue",
        "bindings": [{ "exchange": "repair_exchange", "routing_key": "repair.request" }],
        "consumers": ["anomaly-manager"],
        "producers": ["anomaly-manager"],
        "arguments": {
          "x-dead-letter-exchange": "repair_dlx",
          "x-dead-letter-routing-key": "repair.retry"
        }
      },
      {
        "name": "repair_dlx_queue",
        "bindings": [{ "exchange": "repair_dlx", "routing_key": "repair.retry" }],
        "consumers": ["anomaly-manager"],
        "producers": ["anomaly-manager"],
        "arguments": {
          "x-message-ttl": 3000,
          "x-dead-letter-exchange": "repair_exchange",
          "x-dead-letter-routing-key": "repair.request"
        }
      },
      {
        "name": "drone_events",
        "bindings": [{ "exchange": "drone_events", "routing_key": "" }],
        "consumers": ["order", "item-delivery"],
        "producers": ["order"]
      }
    ],
    "messages": {
      "droneAnomaly": {
        "routing_key": "drone.anomaly",
        "example": {
          "order_id": 123,
          "drone_id": 7,
          "anomaly": "DRONE_STUCK",
          "timestamp": "2026-04-10T09:15:00Z"
        }
      },
      "flightUpdate": {
        "routing_key": "flight_update",
        "example": {
          "event": "landed",
          "drone_id": 7,
          "order_id": 123,
          "timestamp": "2026-04-10T09:18:00Z"
        }
      },
      "notification": {
        "routing_key": "notifications",
        "example": {
          "emailAddress": "user@example.com",
          "emailSubject": "Delivery update",
          "emailBody": "Your order is now in delivery."
        }
      },
      "orderStatusEvent": {
        "exchange": "drone_events",
        "routing_key": "",
        "example": {
          "order_id": 123,
          "status": "IN_DELIVERY"
        }
      },
      "repairRequest": {
        "exchange": "repair_exchange",
        "routing_key": "repair.request",
        "example": {
          "drone_id": 7,
          "assignment_id": 88,
          "attempt": 1
        }
      }
    }
  }
}
