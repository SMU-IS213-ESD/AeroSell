# Environment variables for AeroSell backend
# Copy this file to .env and fill in the values before running the backend
# Remove the comments and fill in the values for the following variables:

# STRIPE_API_KEY=sk_test_your_secret_key
# STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# RABBITMQ
# RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/
# rabbit_host = rabbitmq
# rabbit_port = 5672

# OpenWeather API key — get one at https://openweathermap.org/api
# OPENWEATHER_API_KEY=your_api_key_here